# ============================================================
# Auto-Clean Licences Pro — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs manquantes
# Ne jamais commiter le fichier .env dans Git
# ============================================================

# --- BigQuery ---
BIGQUERY_PROJECT=itg-btdppublished-gbl-ww-pd
BIGQUERY_BILLING_PROJECT=                        # A CONFIRMER avec Matthieu BUREL

# --- BTDP Groups API ---
API_BASE_URL=https://api.loreal.net/global/it4it/itg-groupsapi/v1
API_TOKEN_URL=https://api.loreal.net/v1/oauth20/token
API_CLIENT_ID=                                   # A OBTENIR auprès de IT-GLOBAL-GCP-BTDP_TEAM_PLATFORMSERVICES@loreal.com
API_CLIENT_SECRET=                               # A OBTENIR auprès de IT-GLOBAL-GCP-BTDP_TEAM_PLATFORMSERVICES@loreal.com
API_SCOPE=BTDPAPI.RW

# --- Groupe AD Licence Pro ---
PRO_LICENSE_GROUP_EMAIL=                         # A CONFIRMER avec Anes / IT (ex: IT-GLOBAL-PBI-PRO@loreal.com)

# --- Comportement du script ---
DRY_RUN=true          # true = simulation sans révocation | false = révocation réelle
BATCH_SIZE=20         # Max 20 par appel API (SafeMode)
RETENTION_DAYS=120    # Jours d'inactivité avant révocation

# --- Export CSV (dry-run) ---
CSV_EXPORT_PATH=./output/dry_run_report.csv   # Chemin du fichier CSV généré en mode dry-run
