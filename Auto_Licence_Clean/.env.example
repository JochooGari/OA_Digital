# ============================================================
# Auto-Clean Licences Pro — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs manquantes
# Ne jamais commiter le fichier .env dans Git
# ============================================================

# --- BigQuery ---
BIGQUERY_PROJECT=itg-btdppublished-gbl-ww-pd
BIGQUERY_BILLING_PROJECT=                        # Ton projet GCP (ex: oa-data-coepowerbi-np)

# --- BTDP Groups API ---
# Auth : Google OAuth2 automatique (service account sur Cloud Run, ADC en local)
# Pas besoin de client_id / client_secret depuis GCP
API_BASE_URL=https://api.loreal.net/global/it4it/itg-groupsapi/v1

# --- Groupe AD Licence Pro ---
PRO_LICENSE_GROUP_EMAIL=                         # A CONFIRMER avec Anes (ex: IT-GLOBAL-PBI-PRO@loreal.com)

# --- Comportement du script ---
DRY_RUN=true          # true = simulation sans révocation | false = révocation réelle
BATCH_SIZE=20         # Taille des batches d'appels API
RETENTION_DAYS=120    # Jours d'inactivité avant révocation

# --- Export CSV (dry-run) ---
CSV_EXPORT_PATH=./output/dry_run_report.csv
